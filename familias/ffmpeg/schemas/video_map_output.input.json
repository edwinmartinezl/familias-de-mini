{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "video_map_output input",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "input_file": {
      "type": "string",
      "description": "Primary video source path or URL."
    },
    "output_file": {
      "type": "string"
    },
    "maps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "required": [
    "input_file",
    "maps",
    "output_file"
  ]
}
