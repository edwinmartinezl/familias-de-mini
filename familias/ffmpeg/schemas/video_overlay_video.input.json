{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "video_overlay_video input",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "input_file": {
      "type": "string",
      "description": "Primary video source path or URL."
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "output_file": {
      "type": "string"
    },
    "x": {
      "type": [
        "integer",
        "string"
      ]
    },
    "y": {
      "type": [
        "integer",
        "string"
      ]
    }
  },
  "required": [
    "input_file",
    "inputs",
    "output_file"
  ]
}
